# Neon PostgreSQL接続文字列
# https://neon.tech でプロジェクト作成後に取得
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth 認証情報
# https://console.cloud.google.com で OAuth 2.0 クライアントIDを作成
# 承認済みリダイレクトURI: https://your-app.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# アプリのベースURL（本番: Vercel URL、ローカル: http://localhost:5173）
BASE_URL=https://your-app.vercel.app
