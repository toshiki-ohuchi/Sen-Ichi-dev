# Neon PostgreSQL 本番DB接続文字列
# https://neon.tech でプロジェクト作成後に取得
DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require

# Neon PostgreSQL テストDB接続文字列（テスト専用ブランチを使用すること）
# ローカルでテストを実行する場合のみ設定する
# TEST_DATABASE_URL=postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require

# アプリのベースURL（本番: Vercel URL、ローカル: http://localhost:5173）
BASE_URL=https://your-app.vercel.app

# Node.js環境（本番: production、ローカル: development）
NODE_ENV=production
